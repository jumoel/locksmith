# Mixed-comment-character file.
; Both ; and # are valid comment markers in .npmrc.

registry=https://registry.npmjs.org/
@company:registry=https://npm.company.com/
@private:registry=https://npm.private.example/path/

//registry.npmjs.org/:_authToken=npm_publicToken
//npm.company.com/:_authToken=${COMPANY_NPM_TOKEN}
//npm.private.example/path/:_auth=Zm9vOmJhcg==
//npm.private.example/path/:always-auth=true

strict-ssl=false
cafile=/etc/ssl/internal-ca.pem
before=2025-01-01
legacy-peer-deps=true
engine-strict=true

# array syntax accumulates across lines
omit[] = "dev"
omit[] = "optional"

# quoted value should have quotes stripped
node-version = "20.0.0"
