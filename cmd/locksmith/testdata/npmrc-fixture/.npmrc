; Project-level .npmrc fixture: shape modeled after an Artifactory-using
; project with private scoped registry and corporate CA. Real values redacted.
registry=https://npm.company.com/
@company:registry=https://npm.company.com/scoped/

//npm.company.com/:_authToken=REDACTED-bearer-token
//npm.company.com/scoped/:_auth=Zm9vOmJhcg==

cafile=testdata/npmrc-fixture/fake-ca.pem
legacy-peer-deps=true
engine-strict=true
before=2025-06-01
format-package-lock=false
omit-lockfile-registry-resolved=true
